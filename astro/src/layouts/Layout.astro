---
interface Props {
    title: string;
    description: string;
    mainClass?: string;
}

import { ClientRouter } from "astro:transitions";
import SvelteNav from "../components/svelte/Nav.svelte";

const { title, description, mainClass = "m-8" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <script is:inline>
            (function () {
                function applyTheme() {
                    try {
                        const theme = localStorage.getItem("theme");
                        const prefersDark =
                            window.matchMedia &&
                            window.matchMedia("(prefers-color-scheme: dark)")
                                .matches;
                        if (
                            theme === "dark" ||
                            (theme === null && prefersDark)
                        ) {
                            document.documentElement.classList.add("dark");
                        } else {
                            document.documentElement.classList.remove("dark");
                        }
                    } catch (e) {
                        /* ignore */
                    }
                }

                try {
                    if (!window.__applyTheme) {
                        window.__applyTheme = applyTheme;
                    }
                    // initial
                    applyTheme();
                    // re-apply on client-side navigation via ClientRouter events
                    window.addEventListener("astro:click", applyTheme);
                    window.addEventListener("astro:navigate", applyTheme);
                    window.addEventListener("popstate", applyTheme);
                } catch (e) {
                    /* ignore */
                }
            })();
        </script>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <meta name="author" content="Tobias Kendlbacher" />
        <meta
            name="keywords"
            content="Kendlbacher, Developer, Portfolio, Tobias Kendlbacher, Kendlbacher Austria, Kendlbacher HTL Villach"
        />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <style is:global>
            @keyframes bounce-horiz {
                0%,
                100% {
                    transform: translateX(0);
                    animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
                }
                50% {
                    transform: translateX(30%);
                    animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
                }
            }

            .animate-bounce-lr {
                animation: bounce-horiz 1s infinite;
            }

            .animate-bounce-rl {
                animation: bounce-horiz 1s infinite reverse;
            }
        </style>

        <ClientRouter />
    </head>
    <body class="bg-white transition-colors duration-[700] dark:bg-gray-800">
        <SvelteNav client:load activeUrl={Astro.url.pathname} />
        <main class={mainClass}>
            <slot />
        </main>
        <script is:inline>
            fetch("https://api.kendlbat.dev/open/analytics");
        </script>
    </body>
</html>
