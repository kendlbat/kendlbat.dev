---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Putzplan" description="Putzplan nach KW">
    <section class="mx-auto max-w-2xl p-4 text-gray-900 dark:text-gray-100">
        <h1 class="mb-3 text-3xl font-bold">Putzplan</h1>
        <div id="weeks"></div>
    </section>

    <script is:inline>
        const rooms = [
            { number: 1, name: "Reissner" },
            { number: 2, name: "Tripolt" },
            { number: 3, name: "Kendlbacher" },
        ];

        const duties = {
            1: "Küche + Müll",
            2: "WC",
            3: "Bad",
        };

        function getIsoCalendarWeek(date) {
            const d = new Date(
                Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()),
            );
            const day = d.getUTCDay() || 7;
            d.setUTCDate(d.getUTCDate() + 4 - day);
            const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
            return Math.ceil(((d - yearStart) / 86400000 + 1) / 7);
        }

        function getIsoWeekMonday(date) {
            const d = new Date(
                Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()),
            );
            const day = d.getUTCDay() || 7;
            d.setUTCDate(d.getUTCDate() - day + 1);
            return d;
        }

        function formatDate(date) {
            return `${date.getDate()}.${date.getMonth() + 1}.`;
        }

        const weeksElement = document.getElementById("weeks");

        if (weeksElement) {
            const weekSections = [
                { label: "Aktuelle Woche", weekOffset: 0 },
                { label: "Nächste Woche", weekOffset: 1 },
            ];

            for (const { label, weekOffset } of weekSections) {
                const monday = getIsoWeekMonday(new Date());
                monday.setUTCDate(monday.getUTCDate() + weekOffset * 7);
                const sunday = new Date(monday);
                sunday.setUTCDate(sunday.getUTCDate() + 6);
                const week = getIsoCalendarWeek(monday);

                const section = document.createElement("section");
                section.className = "mb-6";

                const headline = document.createElement("h2");
                headline.className = "text-lg font-semibold";
                headline.textContent = `${label} (KW ${week})`;
                section.appendChild(headline);

                const dateRange = document.createElement("p");
                dateRange.className = "mb-2";
                dateRange.textContent = `${formatDate(monday)} - ${formatDate(
                    sunday,
                )}`;
                section.appendChild(dateRange);

                const assignmentsElement = document.createElement("ul");
                assignmentsElement.className = "list-disc space-y-2 pl-6";

                for (const room of rooms) {
                    const formulaResult = (week % 3) + room.number;
                    const dutyNumber = ((formulaResult - 1) % 3) + 1;
                    const listItem = document.createElement("li");
                    listItem.textContent = `${room.number} ${room.name}: ${duties[dutyNumber]}`;
                    assignmentsElement.appendChild(listItem);
                }

                section.appendChild(assignmentsElement);
                weeksElement.appendChild(section);
            }
        }
    </script>
</Layout>
