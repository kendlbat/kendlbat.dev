---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Putzplan" description="Putzplan nach Kalenderwoche">
    <section class="mx-auto max-w-2xl p-4 text-gray-900 dark:text-gray-100">
        <h1 class="mb-3 text-3xl font-bold">Putzplan</h1>
        <p class="mb-6 text-lg">
            Kalenderwoche: <span id="calendar-week" class="font-semibold">...</span>
        </p>
        <ul id="assignments" class="list-disc space-y-2 pl-6"></ul>
    </section>

    <script is:inline>
        const rooms = [
            { number: 1, name: "Reissner" },
            { number: 2, name: "Tripolt" },
            { number: 3, name: "Kendlbacher" },
        ];

        const duties = {
            1: "Küche + Müll",
            2: "WC",
            3: "Bad",
        };

        function getIsoCalendarWeek(date) {
            const d = new Date(
                Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()),
            );
            const day = d.getUTCDay() || 7;
            d.setUTCDate(d.getUTCDate() + 4 - day);
            const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
            return Math.ceil(((d - yearStart) / 86400000 + 1) / 7);
        }

        const week = getIsoCalendarWeek(new Date());
        const weekElement = document.getElementById("calendar-week");
        const assignmentsElement = document.getElementById("assignments");

        if (weekElement && assignmentsElement) {
            weekElement.textContent = String(week);

            for (const room of rooms) {
                const formulaResult = (week % 3) + room.number;
                const dutyNumber = ((formulaResult - 1) % 3) + 1;
                const listItem = document.createElement("li");
                listItem.textContent = `${room.number} ${room.name}: ${duties[dutyNumber]}`;
                assignmentsElement.appendChild(listItem);
            }
        }
    </script>
</Layout>
